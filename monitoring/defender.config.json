    "bridge_adapter_health": {
      "name": "Bridge Adapter Health",
      "description": "Monitor bridge adapter failures and degradation across all 9 adapters",
      "type": "BLOCK",
      "network": "mainnet",
      "addresses": [],
      "abi": [],
      "eventConditions": [
        {
          "eventSignature": "BridgeStatusUpdated(uint8,uint8)",
          "expression": null
