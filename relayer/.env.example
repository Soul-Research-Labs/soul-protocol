# Relayer Environment Configuration
# Copy to .env and fill in values before running docker-compose up

# ── Required ──
ETHEREUM_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
BASE_RPC_URL=

# SECURITY: Store securely. Never commit the actual .env file.
# Use a secrets manager (Vault, AWS Secrets Manager) in production.
RELAYER_PRIVATE_KEY=

# Redis auth password. Must be set — compose will fail closed without it
# to prevent accidentally exposing nonce/replay state.
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=

# ── Optional (have defaults in docker-compose.yml) ──
# NODE_ENV=production
# LOG_LEVEL=info
# CHAINS=ethereum,arbitrum,optimism,base,aztec
